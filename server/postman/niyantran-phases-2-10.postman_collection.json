{
  "info": {
    "name": "Niyantran Phases 2-10",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "End-to-end Niyantran flow: candidate state machine, NDA, tasks, notifications, SETU sync, and idempotent submissions."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001" },
    { "key": "token", "value": "" },
    { "key": "traceId", "value": "trace_manual_001" },
    { "key": "candidateObjectId", "value": "" },
    { "key": "candidateBusinessId", "value": "" },
    { "key": "ndaId", "value": "" },
    { "key": "taskObjectId", "value": "" },
    { "key": "taskBusinessId", "value": "" },
    { "key": "idempotencyKey", "value": "11111111-1111-1111-1111-111111111111" }
  ],
  "item": [
    {
      "name": "NDA - Upload",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "candidateId", "value": "{{candidateObjectId}}", "type": "text" },
            { "key": "file", "type": "file", "src": "" }
          ]
        },
        "url": "{{baseUrl}}/api/niyantran/nda/upload"
      }
    },
    {
      "name": "NDA - Sign",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ndaId\": \"{{ndaId}}\",\n  \"signatureHash\": \"sha256:sample-signature\",\n  \"ip\": \"127.0.0.1\",\n  \"userAgent\": \"Postman\"\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/nda/sign"
      }
    },
    {
      "name": "NDA - Submit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"ndaId\": \"{{ndaId}}\"\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/nda/submit"
      }
    },
    {
      "name": "Task - Assign",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"candidateId\": \"{{candidateObjectId}}\",\n  \"title\": \"Build deterministic API\",\n  \"description\": \"Implement deterministic transitions\",\n  \"instructions\": \"Submit github link and notes\",\n  \"attachedFiles\": [],\n  \"dueDate\": \"2026-04-10T00:00:00.000Z\"\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/tasks/assign"
      }
    },
    {
      "name": "Task - Edit",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Build deterministic API - Updated\"\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/tasks/{{taskBusinessId}}"
      }
    },
    {
      "name": "Task - Reassign",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Replacement Task\",\n  \"description\": \"New assignment\",\n  \"instructions\": \"Submit updated solution\"\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/tasks/{{taskBusinessId}}/reassign"
      }
    },
    {
      "name": "Task - My Active Task",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "url": "{{baseUrl}}/api/niyantran/tasks/my-task?candidateId={{candidateObjectId}}"
      }
    },
    {
      "name": "Task - Submit (Idempotent)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" },
          { "key": "x-trace-id", "value": "{{traceId}}" },
          { "key": "x-idempotency-key", "value": "{{idempotencyKey}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"taskId\": \"{{taskBusinessId}}\",\n  \"candidateId\": \"{{candidateObjectId}}\",\n  \"submissionType\": \"link\",\n  \"content\": \"https://github.com/example/repo\",\n  \"fileUrls\": []\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/tasks/submit"
      }
    },
    {
      "name": "Notification - Manual Trigger",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-auth-token", "value": "{{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventType\": \"task_assigned\",\n  \"candidateId\": \"{{candidateObjectId}}\",\n  \"data\": {\n    \"task\": {\n      \"title\": \"Manual test task\",\n      \"description\": \"manual trigger\",\n      \"dueDate\": \"2026-04-10T00:00:00.000Z\"\n    }\n  }\n}"
        },
        "url": "{{baseUrl}}/api/niyantran/notifications/manual-trigger"
      }
    },
    {
      "name": "Notification - Run Reminders",
      "request": {
        "method": "POST",
        "header": [
          { "key": "x-auth-token", "value": "{{token}}" }
        ],
        "url": "{{baseUrl}}/api/niyantran/notifications/run-reminders"
      }
    },
    {
      "name": "SETU - Candidates",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "url": "{{baseUrl}}/api/setu/candidates"
      }
    },
    {
      "name": "SETU - Candidate Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "url": "{{baseUrl}}/api/setu/candidates/{{candidateObjectId}}"
      }
    },
    {
      "name": "SETU - Active Tasks",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "url": "{{baseUrl}}/api/setu/tasks"
      }
    },
    {
      "name": "SETU - Dashboard Feed",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-trace-id", "value": "{{traceId}}" }
        ],
        "url": "{{baseUrl}}/api/setu/dashboard-feed"
      }
    }
  ]
}
